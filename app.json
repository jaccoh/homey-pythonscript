{
  "id": "nl.hoeve.pythonscript",
  "version": "0.2.2",
  "compatibility": ">=13.0.0",
  "runtime": "python",
  "pythonVersion": "3.14",
  "sdk": 3,
  "name": {
    "en": "Python Script",
    "nl": "Python Script"
  },
  "description": {
    "en": "Run Python code from Advanced Flows",
    "nl": "Voer Python-code uit vanuit Advanced Flows"
  },
  "category": [
    "tools"
  ],
  "platforms": [
    "local"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "brandColor": "#3572A5",
  "author": {
    "name": "Jacco Hoeve"
  },
  "bugs": {
    "url": "https://github.com/jaccoh/homey-pythonscript/issues"
  },
  "homepage": "https://github.com/jaccoh/homey-pythonscript",
  "support": "https://community.homey.app/t/app-pro-python-script/157001",
  "source": "https://github.com/jaccoh/homey-pythonscript",
  "pythonPackages": [
    "restrictedpython>=7.0.0"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "api": {
    "venvs": {
      "method": "GET",
      "path": "/venvs"
    },
    "build_venv": {
      "method": "POST",
      "path": "/venv-build"
    },
    "delete_venv": {
      "method": "POST",
      "path": "/venv-delete"
    },
    "scripts": {
      "method": "GET",
      "path": "/scripts"
    },
    "get_script": {
      "method": "POST",
      "path": "/script-get"
    },
    "save_script": {
      "method": "POST",
      "path": "/script-save"
    },
    "delete_script": {
      "method": "POST",
      "path": "/script-delete"
    },
    "run_script_api": {
      "method": "POST",
      "path": "/script-run"
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "python_triggered",
        "title": {
          "en": "Flow triggered from Python",
          "nl": "Flow getriggerd vanuit Python"
        },
        "titleFormatted": {
          "en": "Flow triggered from Python with tag [[tag]]",
          "nl": "Flow getriggerd vanuit Python met tag [[tag]]"
        },
        "args": [
          {
            "name": "tag",
            "type": "text",
            "title": {
              "en": "Tag (optional)",
              "nl": "Tag (optioneel)"
            },
            "placeholder": {
              "en": "my-flow"
            },
            "required": false
          }
        ],
        "tokens": []
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Run Named Script",
          "nl": "Bewaard script uitvoeren"
        },
        "titleFormatted": {
          "en": "Run [[script_name]] with [[argument]]",
          "nl": "Voer [[script_name]] uit met [[argument]]"
        },
        "highlight": true,
        "args": [
          {
            "name": "script_name",
            "type": "autocomplete",
            "title": {
              "en": "Script",
              "nl": "Script"
            },
            "placeholder": {
              "en": "Select a saved script"
            }
          },
          {
            "name": "argument",
            "type": "text",
            "title": {
              "en": "Argument (optional)",
              "nl": "Argument (optioneel)"
            },
            "placeholder": {
              "en": "Value passed as `args`"
            },
            "required": false
          }
        ],
        "tokens": [
          {
            "name": "return_value",
            "type": "string",
            "title": {
              "en": "Return value",
              "nl": "Returnwaarde"
            },
            "example": "42"
          }
        ],
        "id": "run_named_script"
      },
      {
        "title": {
          "en": "Run Script",
          "nl": "Script uitvoeren"
        },
        "titleFormatted": {
          "en": "Run [[script]] with [[argument]] (timeout: [[timeout]]s)",
          "nl": "Voer [[script]] uit met [[argument]] (timeout: [[timeout]]s)"
        },
        "highlight": true,
        "args": [
          {
            "name": "script",
            "type": "code",
            "title": {
              "en": "Script",
              "nl": "Script"
            },
            "placeholder": {
              "en": "return 42"
            }
          },
          {
            "name": "argument",
            "type": "text",
            "title": {
              "en": "Argument (optional)",
              "nl": "Argument (optioneel)"
            },
            "placeholder": {
              "en": "Value passed as `args`"
            },
            "required": false
          },
          {
            "name": "timeout",
            "type": "number",
            "title": {
              "en": "Timeout (seconds)",
              "nl": "Time-out (seconden)"
            },
            "placeholder": {
              "en": "30"
            },
            "min": 1,
            "max": 300,
            "required": false
          }
        ],
        "tokens": [
          {
            "name": "return_value",
            "type": "string",
            "title": {
              "en": "Return value",
              "nl": "Returnwaarde"
            },
            "example": "42"
          }
        ],
        "id": "run_script"
      },
      {
        "title": {
          "en": "Run Script with Packages",
          "nl": "Script uitvoeren met packages"
        },
        "titleFormatted": {
          "en": "Run [[script]] with [[requirements]] in [[venv_name]] [[argument]] (timeout: [[timeout]]s)",
          "nl": "Voer [[script]] uit met [[requirements]] in [[venv_name]] [[argument]] (timeout: [[timeout]]s)"
        },
        "highlight": true,
        "args": [
          {
            "name": "script",
            "type": "code",
            "title": {
              "en": "Script",
              "nl": "Script"
            },
            "placeholder": {
              "en": "import requests\nreturn requests.get('https://example.com').status_code"
            }
          },
          {
            "name": "argument",
            "type": "text",
            "title": {
              "en": "Argument (optional)",
              "nl": "Argument (optioneel)"
            },
            "placeholder": {
              "en": "Value passed as `args`"
            },
            "required": false
          },
          {
            "name": "requirements",
            "type": "code",
            "title": {
              "en": "Requirements (pip format)",
              "nl": "Requirements (pip-formaat)"
            },
            "placeholder": {
              "en": "requests==2.31.0\nnumpy>=1.26.0"
            }
          },
          {
            "name": "venv_name",
            "type": "autocomplete",
            "title": {
              "en": "Environment name",
              "nl": "Omgevingsnaam"
            },
            "placeholder": {
              "en": "my-env"
            }
          },
          {
            "name": "timeout",
            "type": "number",
            "title": {
              "en": "Timeout (seconds)",
              "nl": "Time-out (seconden)"
            },
            "placeholder": {
              "en": "30"
            },
            "min": 1,
            "max": 300,
            "required": false
          }
        ],
        "tokens": [
          {
            "name": "return_value",
            "type": "string",
            "title": {
              "en": "Return value",
              "nl": "Returnwaarde"
            },
            "example": "42"
          }
        ],
        "id": "run_script_with_argument"
      }
    ]
  }
}