{
  "id": "nl.hoeve.pythonscript",
  "version": "0.1.0",
  "compatibility": ">=13.0.0",
  "runtime": "python",
  "pythonVersion": "3.14",
  "sdk": 3,
  "name": {
    "en": "Python Script",
    "nl": "Python Script"
  },
  "description": {
    "en": "Run Python code from Advanced Flows",
    "nl": "Voer Python-code uit vanuit Advanced Flows"
  },
  "category": [
    "tools"
  ],
  "platforms": [
    "local"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "brandColor": "#3572A5",
  "author": {
    "name": "Jacco Hoeve"
  },
  "pythonPackages": [
    "restrictedpython>=7.0.0"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "api": {
    "venvs": {
      "method": "GET",
      "path": "/venvs"
    },
    "delete_venv": {
      "method": "POST",
      "path": "/venv-delete"
    }
  },
  "flow": {
    "actions": [
      {
        "title": {
          "en": "Run Script",
          "nl": "Script uitvoeren"
        },
        "highlight": true,
        "args": [
          {
            "name": "script",
            "type": "code",
            "title": {
              "en": "Script",
              "nl": "Script"
            },
            "placeholder": {
              "en": "return 42"
            }
          },
          {
            "name": "argument",
            "type": "text",
            "title": {
              "en": "Argument (optional)",
              "nl": "Argument (optioneel)"
            },
            "placeholder": {
              "en": "Value passed as `args`"
            },
            "required": false
          },
          {
            "name": "timeout",
            "type": "number",
            "title": {
              "en": "Timeout (seconds)",
              "nl": "Time-out (seconden)"
            },
            "placeholder": {
              "en": "30"
            },
            "min": 1,
            "max": 300,
            "required": false
          }
        ],
        "tokens": [
          {
            "name": "return_value",
            "type": "string",
            "title": {
              "en": "Return value",
              "nl": "Returnwaarde"
            },
            "example": "42"
          }
        ],
        "id": "run_script"
      },
      {
        "title": {
          "en": "Run Script with Packages",
          "nl": "Script uitvoeren met packages"
        },
        "highlight": true,
        "args": [
          {
            "name": "script",
            "type": "code",
            "title": {
              "en": "Script",
              "nl": "Script"
            },
            "placeholder": {
              "en": "import requests\nreturn requests.get('https://example.com').status_code"
            }
          },
          {
            "name": "argument",
            "type": "text",
            "title": {
              "en": "Argument (optional)",
              "nl": "Argument (optioneel)"
            },
            "placeholder": {
              "en": "Value passed as `args`"
            },
            "required": false
          },
          {
            "name": "requirements",
            "type": "code",
            "title": {
              "en": "Requirements (pip format)",
              "nl": "Requirements (pip-formaat)"
            },
            "placeholder": {
              "en": "requests==2.31.0\nnumpy>=1.26.0"
            }
          },
          {
            "name": "venv_name",
            "type": "autocomplete",
            "title": {
              "en": "Environment name",
              "nl": "Omgevingsnaam"
            },
            "placeholder": {
              "en": "my-env"
            }
          },
          {
            "name": "timeout",
            "type": "number",
            "title": {
              "en": "Timeout (seconds)",
              "nl": "Time-out (seconden)"
            },
            "placeholder": {
              "en": "30"
            },
            "min": 1,
            "max": 300,
            "required": false
          }
        ],
        "tokens": [
          {
            "name": "return_value",
            "type": "string",
            "title": {
              "en": "Return value",
              "nl": "Returnwaarde"
            },
            "example": "42"
          }
        ],
        "id": "run_script_with_argument"
      }
    ]
  }
}