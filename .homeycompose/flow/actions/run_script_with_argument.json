{
  "title": { "en": "Run Script with Packages", "nl": "Script uitvoeren met packages" },
  "titleFormatted": { "en": "Run script with packages in [[venv_name]]", "nl": "Voer script uit met packages in [[venv_name]]" },
  "highlight": true,
  "args": [
    {
      "name": "script",
      "type": "code",
      "title": { "en": "Script", "nl": "Script" },
      "placeholder": { "en": "import requests\nreturn requests.get('https://example.com').status_code" }
    },
    {
      "name": "argument",
      "type": "text",
      "title": { "en": "Argument (optional)", "nl": "Argument (optioneel)" },
      "placeholder": { "en": "Value passed as `args`" },
      "required": false
    },
    {
      "name": "requirements",
      "type": "code",
      "title": { "en": "Requirements (pip format)", "nl": "Requirements (pip-formaat)" },
      "placeholder": { "en": "requests==2.31.0\nnumpy>=1.26.0" }
    },
    {
      "name": "venv_name",
      "type": "autocomplete",
      "title": { "en": "Environment name", "nl": "Omgevingsnaam" },
      "placeholder": { "en": "my-env" }
    },
    {
      "name": "timeout",
      "type": "number",
      "title": { "en": "Timeout (seconds)", "nl": "Time-out (seconden)" },
      "placeholder": { "en": "30" },
      "min": 1,
      "max": 300,
      "required": false
    }
  ],
  "tokens": [
    { "name": "return_value", "type": "string", "title": { "en": "Return value", "nl": "Returnwaarde" }, "example": "42" }
  ]
}
